<file path="src/parser/gherkin.pest">
/// Gherkin grammar for parsing feature files

// Comments
comment = { "#" ~ (!("\n" | "\r") ~ ANY)* }

// Tags
tag = { "@" ~ (!" " ~ !"\n" ~ !"\r" ~ ANY)* }
tags = { tag ~ (" " ~ tag)* }

// Feature header
feature_name = { (!("\n" | "\r") ~ ANY)+ }
description_line = { " "+ ~ (!("\n" | "\r" | "Scenario:" | "Background:" | "Scenario Outline:" | "Scenario Template:" | "Examples:" | "Scenarios:" | "@") ~ ANY)+ ~ ("\n" | "\r")* }
description = { description_line+ }

// Steps - indented with keyword
step = { " "* ~ ("Given" | "When" | "Then" | "And" | "But" | "Dado" | "Quando" | "Então" | "E" | "Mas") ~ " "+ ~ (!"\n" ~ !"\r" ~ ANY)+ }

// Background
background = {
    " "* ~ "Background:" ~ " "* ~ (!("\n" | "\r") ~ ANY)* ~ ("\n" | "\r")*
    ~ (step ~ ("\n" | "\r")*)*
}

// Scenario
scenario = {
    " "* ~ tags? ~ ("\n" | "\r")*
    ~ " "* ~ "Scenario:" ~ " "+ ~ scenario_name ~ ("\n" | "\r")*
    ~ (step ~ ("\n" | "\r")*)*
}

scenario_name = { (!"\n" ~ !"\r" ~ ANY)+ }

// Scenario Outline
scenario_outline = {
    " "* ~ tags? ~ ("\n" | "\r")*
    ~ " "* ~ ("Scenario Outline:" | "Scenario Template:") ~ " "+ ~ scenario_name ~ ("\n" | "\r")*
    ~ (step ~ ("\n" | "\r")*)*
    ~ examples
}

// Examples and Tables
table_cell = { (!("|" | "\n" | "\r") ~ ANY)* }
table_row = { "|" ~ (" "* ~ table_cell ~ " "* ~ "|")+ }
table = { table_row ~ ("\n" ~ table_row)* }

examples = {
    " "* ~ ("Examples:" | "Scenarios:") ~ " "* ~ (!("\n" | "\r") ~ ANY)* ~ ("\n" | "\r")*
    ~ table
}

// Main feature rule
feature = {
    ((" " | "\n" | "\r") | comment)* ~ tags? ~ ((" " | "\n" | "\r") | comment)*
    ~ "Feature:" ~ " "+ ~ feature_name
    ~ (("\n" | "\r")* ~ description)?
    ~ (("\n" | "\r")* ~ (background | scenario | scenario_outline | comment))*
    ~ ("\n" | "\r" | " ")*
    ~ EOI
}
